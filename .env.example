# PostgreSQL database (required)
DATABASE_URL="postgresql://user@localhost:5432/malsat"

# JWT secret (required — generate with: openssl rand -hex 32)
JWT_SECRET="change-me-to-a-random-32-byte-hex-string"

# Environment
NODE_ENV="development"

# Anthropic API key for AI photo analysis (optional, feature disabled without it)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=""
