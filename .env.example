# ═══════════════════════════════════════════════════════════════════
# MalSat backend — environment template
# Copy to .env.production (or .env for dev) and fill in real values.
# ═══════════════════════════════════════════════════════════════════

# ─── Database (required) ───────────────────────────────────────────
# PostgreSQL connection string. On the self-hosted altailabs server
# this is localhost; on Vercel/Supabase/Neon use the pooled URL.
DATABASE_URL="postgresql://user:password@localhost:5432/malsat"

# ─── Auth (required) ───────────────────────────────────────────────
# Sign the JWT access / refresh tokens. Generate a fresh value per
# environment: `openssl rand -hex 32`.
JWT_SECRET="change-me-to-a-random-32-byte-hex-string"

# ─── Environment ───────────────────────────────────────────────────
NODE_ENV="production"

# ─── Public URL of this backend (required) ─────────────────────────
# Used to build absolute URLs for uploaded media (/uploads/...).
# No trailing slash.
PUBLIC_BASE_URL="https://malsat.altailabs.club"

# ─── SMS / OTP via smspro.nikita.kg (required for real logins) ─────
# Leave SMS_LOGIN / SMS_PASSWORD / SMS_SENDER empty to skip real SMS
# (the OTP is just logged to pm2 stdout — fine for local dev and
# App Store review via the +996555000000 / 000000 bypass).
#
# SMS_TEMPLATE must match, byte-for-byte, the template you registered
# in Nikita's admin panel (service traffic, 1.28–1.64 сом / SMS).
# Use {CODE} as the 6-digit placeholder. No leading/trailing spaces.
SMS_LOGIN=""
SMS_PASSWORD=""
SMS_SENDER="malsat.kg"
SMS_TEMPLATE='"MalSat" kyzmatyna kattaluu uchun sms code: {CODE}'

# ─── AI photo analysis (optional) ──────────────────────────────────
# Enables Claude Vision auto-fill when a seller uploads a listing
# photo. Feature is silently disabled if this is blank.
# https://console.anthropic.com
ANTHROPIC_API_KEY=""
