generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AnimalCategory {
  HORSE
  CATTLE
  SHEEP
  ARASHAN
}

enum AnimalGender {
  MALE
  FEMALE
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
}

enum MediaType {
  PHOTO
  VIDEO
}

enum RegionType {
  OBLAST
  RAYON
  VILLAGE
}

model User {
  id                String   @id @default(cuid())
  phone             String   @unique
  name              String?
  avatarUrl         String?
  regionId          String?
  village           String?
  bio               String?
  trustScore        Float    @default(0)
  isVerifiedBreeder Boolean  @default(false)
  paymentQrUrl      String? // seller's bank QR code image URL
  paymentInfo       String? // e.g. "Mbank: +996555123456" or bank name
  savedAddress      String? // buyer's saved delivery address
  savedAddressLat   Float?
  savedAddressLng   Float?
  preferredLang     String   @default("ky")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  region                 Region?           @relation(fields: [regionId], references: [id])
  listings               Listing[]
  reviewsGiven           Review[]          @relation("ReviewerReviews")
  reviewsReceived        Review[]          @relation("SellerReviews")
  favorites              Favorite[]
  conversationsAsBuyer   Conversation[]    @relation("BuyerConversations")
  conversationsAsSeller  Conversation[]    @relation("SellerConversations")
  messagesSent           Message[]
  savedSearches          SavedSearch[]
  drops                  ButcherDrop[]     @relation("SellerDrops")
  orders                 MeatOrder[]       @relation("BuyerOrders")
  hubMemberships         HubMember[]
  ownedTokens            TokenHolder[]
  farmerAnimals          LivestockAnimal[] @relation("FarmerAnimals")
  tokenTransfersSent     TokenTransfer[]   @relation("TransferSender")
  tokenTransfersReceived TokenTransfer[]   @relation("TransferReceiver")

  @@index([regionId])
  @@index([phone])
}

model Listing {
  id             String         @id @default(cuid())
  sellerId       String
  category       AnimalCategory
  subcategory    String?
  breed          String?
  title          String
  description    String?
  priceKgs       Int
  ageMonths      Int?
  weightKg       Float?
  gender         AnimalGender?
  healthStatus   String?
  hasVetCert     Boolean        @default(false)
  locationLat    Float?
  locationLng    Float?
  regionId       String?
  village        String?
  status         ListingStatus  @default(ACTIVE)
  viewsCount     Int            @default(0)
  favoritesCount Int            @default(0)
  isPremium      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  expiresAt      DateTime?

  seller        User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  region        Region?        @relation(fields: [regionId], references: [id])
  media         ListingMedia[]
  reviews       Review[]
  favorites     Favorite[]
  conversations Conversation[]

  @@index([sellerId])
  @@index([category])
  @@index([status])
  @@index([regionId])
  @@index([priceKgs])
  @@index([createdAt])
  @@index([category, status, createdAt])
}

model ListingMedia {
  id        String    @id @default(cuid())
  listingId String
  mediaUrl  String
  mediaType MediaType @default(PHOTO)
  isPrimary Boolean   @default(false)
  sortOrder Int       @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  sellerId   String
  listingId  String?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  reviewer User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  seller   User     @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)
  listing  Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([sellerId])
  @@index([reviewerId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
}

model Conversation {
  id            String   @id @default(cuid())
  listingId     String?
  buyerId       String
  sellerId      String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([buyerId, sellerId, listingId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  mediaUrl       String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Region {
  id       String     @id @default(cuid())
  nameKy   String
  nameRu   String
  parentId String?
  type     RegionType
  lat      Float?
  lng      Float?

  parent   Region?       @relation("RegionHierarchy", fields: [parentId], references: [id])
  children Region[]      @relation("RegionHierarchy")
  users    User[]
  listings Listing[]
  drops    ButcherDrop[]
  hubs     Hub[]

  @@index([parentId])
  @@index([type])
}

model SavedSearch {
  id                  String   @id @default(cuid())
  userId              String
  filtersJson         String
  notificationEnabled Boolean  @default(true)
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
}

// ─── Butcher Drops (meat ordering) ───────────────────────────

enum DropStatus {
  UPCOMING
  OPEN
  SOLD_OUT
  FULFILLED
  CANCELLED
}

enum OrderStatus {
  PENDING // buyer placed order, awaiting payment
  PAID // buyer uploaded receipt, awaiting seller verification
  CONFIRMED // seller verified payment
  BUTCHERING // animal is being butchered
  PACKAGING // meat is being packaged
  DELIVERING // on the way to buyer
  DELIVERED // buyer received meat
  CANCELLED
}

model ButcherDrop {
  id                String         @id @default(cuid())
  sellerId          String
  title             String
  description       String?
  category          AnimalCategory
  breed             String?
  totalWeightKg     Float
  remainingWeightKg Float
  pricePerKg        Int
  minOrderKg        Float          @default(3)
  maxOrderKg        Float?
  portionPresets    String         @default("[5,10,15]") // JSON array
  butcherDate       DateTime
  pickupAddress     String
  pickupLat         Float?
  pickupLng         Float?
  regionId          String?
  village           String?
  deliveryAvailable Boolean        @default(false)
  deliveryFee       Int            @default(0) // KGS, 0 = free delivery
  deliveryRadius    String? // e.g. "Бишкек шаары", "Чүй облусу"
  status            DropStatus     @default(OPEN)
  viewsCount        Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  expiresAt         DateTime?

  seller   User        @relation("SellerDrops", fields: [sellerId], references: [id], onDelete: Cascade)
  region   Region?     @relation(fields: [regionId], references: [id])
  media    DropMedia[]
  orders   MeatOrder[]
  hubDrops HubDrop[] // which hubs this drop targets

  @@index([sellerId])
  @@index([status])
  @@index([category])
  @@index([regionId])
  @@index([butcherDate])
  @@index([status, category, butcherDate])
}

model DropMedia {
  id        String    @id @default(cuid())
  dropId    String
  mediaUrl  String
  mediaType MediaType @default(PHOTO)
  isPrimary Boolean   @default(false)
  sortOrder Int       @default(0)

  drop ButcherDrop @relation(fields: [dropId], references: [id], onDelete: Cascade)

  @@index([dropId])
}

model MeatOrder {
  id                 String      @id @default(cuid())
  dropId             String
  buyerId            String
  weightKg           Float
  totalPriceKgs      Int
  deliveryMethod     String      @default("pickup") // "pickup" or "delivery"
  deliveryAddress    String? // buyer's delivery address
  deliveryLat        Float?
  deliveryLng        Float?
  deliveryFee        Int         @default(0)
  status             OrderStatus @default(PENDING)
  buyerPhone         String?
  buyerNote          String?
  receiptUrl         String? // buyer uploads bank transfer screenshot
  butcheringPhotoUrl String? // seller documents: animal being butchered
  packagingPhotoUrl  String? // seller documents: meat packaged for buyer
  deliveringPhotoUrl String? // seller documents: package in transit / at door
  paidAt             DateTime?
  confirmedAt        DateTime?
  butcheringAt       DateTime?
  packagingAt        DateTime?
  deliveringAt       DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime    @default(now())

  drop  ButcherDrop @relation(fields: [dropId], references: [id], onDelete: Cascade)
  buyer User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([dropId])
  @@index([buyerId])
  @@index([status])
}

// ─── Hubs (Apartment complexes / Neighborhoods) ──────────────

model Hub {
  id          String   @id @default(cuid())
  name        String // "7-кичи район, 21-үй" or "Асанбай, Блок-А"
  address     String
  lat         Float?
  lng         Float?
  regionId    String?
  city        String?
  code        String   @unique // 6-char join code: "MAL-7KR"
  photoUrl    String?
  createdById String
  createdAt   DateTime @default(now())

  region  Region?     @relation(fields: [regionId], references: [id])
  members HubMember[]
  drops   HubDrop[] // drops targeted at this hub

  @@index([code])
  @@index([regionId])
}

enum HubRole {
  ADMIN // created the hub, manages it
  MEMBER
}

model HubMember {
  id        String   @id @default(cuid())
  hubId     String
  userId    String
  role      HubRole  @default(MEMBER)
  apartment String? // "45-кв" — so the farmer knows which door
  joinedAt  DateTime @default(now())

  hub  Hub  @relation(fields: [hubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hubId, userId])
  @@index([hubId])
  @@index([userId])
}

// Connects a drop to one or more hubs (farmer targets delivery to buildings)
model HubDrop {
  id     String @id @default(cuid())
  hubId  String
  dropId String

  hub  Hub         @relation(fields: [hubId], references: [id], onDelete: Cascade)
  drop ButcherDrop @relation(fields: [dropId], references: [id], onDelete: Cascade)

  @@unique([hubId, dropId])
  @@index([hubId])
  @@index([dropId])
}

// ─── Livestock Tokens (fractional animal ownership) ──────────

enum AnimalStatus {
  GRAZING // alive, gaining weight
  LISTED // farmer listed for tokenized sale
  FULLY_OWNED // all tokens sold
  BUTCHER_SCHEDULED // butcher date set, tokens lock
  BUTCHERED // meat distributed to token holders
}

enum TokenTransferType {
  BUY // bought from farmer (primary market)
  SELL // sold to another user (secondary market)
  REDEEM // redeemed for meat at butcher time
}

model LivestockAnimal {
  id              String         @id @default(cuid())
  farmerId        String
  name            String // "Кара-Бука", "Бозторгой"
  category        AnimalCategory
  breed           String?
  gender          AnimalGender?
  birthDate       DateTime?
  photoUrl        String?
  currentWeightKg Float
  healthStatus    String? // "Соо", "Вакцина алынды"
  hasVetCert      Boolean        @default(false)
  locationVillage String?
  locationRegion  String?

  // Tokenization
  totalTokens    Int          @default(10) // 1 animal = N tokens
  tokenPriceKgs  Int // price per token in KGS
  meatPerTokenKg Float // estimated kg of meat per token at butcher
  status         AnimalStatus @default(LISTED)
  butcherDate    DateTime? // when it'll be butchered (if scheduled)

  // Value tracking (like a stock)
  initialPriceKgs Int // IPO price per token
  currentPriceKgs Int // current market price per token
  priceHistory    String @default("[]") // JSON: [{date, price}]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farmer    User            @relation("FarmerAnimals", fields: [farmerId], references: [id], onDelete: Cascade)
  holders   TokenHolder[]
  transfers TokenTransfer[]
  media     AnimalMedia[]

  @@index([farmerId])
  @@index([status])
  @@index([category])
}

model AnimalMedia {
  id        String    @id @default(cuid())
  animalId  String
  mediaUrl  String
  mediaType MediaType @default(PHOTO)
  caption   String? // "3 айлык кезинде", "Жайлоодо"
  takenAt   DateTime  @default(now())

  animal LivestockAnimal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId])
}

model TokenHolder {
  id        String   @id @default(cuid())
  animalId  String
  userId    String
  tokens    Int // how many tokens this user holds
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  animal LivestockAnimal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([animalId, userId])
  @@index([animalId])
  @@index([userId])
}

model TokenTransfer {
  id         String            @id @default(cuid())
  animalId   String
  fromUserId String? // null = bought from farmer (primary)
  toUserId   String
  tokens     Int
  priceKgs   Int // total price for this transfer
  type       TokenTransferType
  receiptUrl String?
  createdAt  DateTime          @default(now())

  animal LivestockAnimal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  from   User?           @relation("TransferSender", fields: [fromUserId], references: [id])
  to     User            @relation("TransferReceiver", fields: [toUserId], references: [id])

  @@index([animalId])
  @@index([toUserId])
  @@index([fromUserId])
}
