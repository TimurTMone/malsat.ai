generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AnimalCategory {
  HORSE
  CATTLE
  SHEEP
  ARASHAN
}

enum AnimalGender {
  MALE
  FEMALE
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
}

enum MediaType {
  PHOTO
  VIDEO
}

enum RegionType {
  OBLAST
  RAYON
  VILLAGE
}

model User {
  id               String    @id @default(cuid())
  phone            String    @unique
  name             String?
  avatarUrl        String?
  regionId         String?
  village          String?
  bio              String?
  trustScore       Float     @default(0)
  isVerifiedBreeder Boolean  @default(false)
  preferredLang    String    @default("ky")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  region           Region?   @relation(fields: [regionId], references: [id])
  listings         Listing[]
  reviewsGiven     Review[]  @relation("ReviewerReviews")
  reviewsReceived  Review[]  @relation("SellerReviews")
  favorites        Favorite[]
  conversationsAsBuyer  Conversation[] @relation("BuyerConversations")
  conversationsAsSeller Conversation[] @relation("SellerConversations")
  messagesSent     Message[]
  savedSearches    SavedSearch[]

  @@index([regionId])
  @@index([phone])
}

model Listing {
  id             String         @id @default(cuid())
  sellerId       String
  category       AnimalCategory
  subcategory    String?
  breed          String?
  title          String
  description    String?
  priceKgs       Int
  ageMonths      Int?
  weightKg       Float?
  gender         AnimalGender?
  healthStatus   String?
  hasVetCert     Boolean        @default(false)
  locationLat    Float?
  locationLng    Float?
  regionId       String?
  village        String?
  status         ListingStatus  @default(ACTIVE)
  viewsCount     Int            @default(0)
  favoritesCount Int            @default(0)
  isPremium      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  expiresAt      DateTime?

  seller         User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  region         Region?        @relation(fields: [regionId], references: [id])
  media          ListingMedia[]
  reviews        Review[]
  favorites      Favorite[]
  conversations  Conversation[]

  @@index([sellerId])
  @@index([category])
  @@index([status])
  @@index([regionId])
  @@index([priceKgs])
  @@index([createdAt])
  @@index([category, status, createdAt])
}

model ListingMedia {
  id        String    @id @default(cuid())
  listingId String
  mediaUrl  String
  mediaType MediaType @default(PHOTO)
  isPrimary Boolean   @default(false)
  sortOrder Int       @default(0)

  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  sellerId   String
  listingId  String?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  reviewer   User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  seller     User     @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)
  listing    Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([sellerId])
  @@index([reviewerId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
}

model Conversation {
  id            String    @id @default(cuid())
  listingId     String?
  buyerId       String
  sellerId      String
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())

  listing       Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  buyer         User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller        User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@unique([buyerId, sellerId, listingId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  mediaUrl       String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Region {
  id       String     @id @default(cuid())
  nameKy   String
  nameRu   String
  parentId String?
  type     RegionType
  lat      Float?
  lng      Float?

  parent   Region?    @relation("RegionHierarchy", fields: [parentId], references: [id])
  children Region[]   @relation("RegionHierarchy")
  users    User[]
  listings Listing[]

  @@index([parentId])
  @@index([type])
}

model SavedSearch {
  id                  String   @id @default(cuid())
  userId              String
  filtersJson         String
  notificationEnabled Boolean  @default(true)
  createdAt           DateTime @default(now())

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
}
